<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>SANO Solutions — Command Center</title>
    <meta name="description" content="SANO Solutions internal command center — AI-first launch tracker with agent pipeline monitoring.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-left">
            <div class="logo">
                <div class="logo-icon">S</div>
                <div class="logo-text">
                    <span class="logo-name">SANO</span>
                    <span class="logo-sub">COMMAND CENTER</span>
                </div>
            </div>
        </div>
        <div class="header-center">
            <div class="header-countdown" id="headerCountdown"></div>
            <div class="header-target">June 1, 2026</div>
        </div>
        <div class="header-right">
            <div class="cmdk-hint" onclick="openCommandPalette()" title="Quick Actions">⌘K</div>
            <div class="date-display" id="currentDate"></div>
            <div class="time-display" id="currentTime"></div>
        </div>
    </header>

    <!-- ===================== ALERT PANEL (Feature 5) ===================== -->
    <div class="alert-panel" id="alertPanel"></div>

    <!-- ===================== TODAY'S FOCUS CARD ===================== -->
    <section class="focus-card" id="focusCard">
        <div class="focus-inner">
            <div class="focus-header">
                <div class="focus-title">
                    <span class="focus-icon">🎯</span>
                    <span>Today's Focus</span>
                </div>
                <div class="focus-date" id="focusDate"></div>
            </div>
            <div class="focus-columns">
                <div class="focus-col">
                    <div class="focus-col-header">
                        <span class="focus-col-icon">👤</span>
                        <span class="focus-col-label">Your Top 5</span>
                        <span class="focus-col-sub">CEO-only actions</span>
                    </div>
                    <div class="focus-items" id="focusJasper"></div>
                </div>
                <div class="focus-divider"></div>
                <div class="focus-col">
                    <div class="focus-col-header">
                        <span class="focus-col-icon">🤖</span>
                        <span class="focus-col-label">Antigravity's Top 5</span>
                        <span class="focus-col-sub">AI can handle today</span>
                    </div>
                    <div class="focus-items" id="focusAI"></div>
                </div>
            </div>
            <div class="focus-complete" id="focusComplete" style="display:none;">
                ✅ Focus Complete — all priorities handled today
            </div>
        </div>
    </section>

    <!-- ===================== KPI STRIP ===================== -->
    <section class="health-strip">
        <div class="health-item">
            <div class="health-top">
                <span class="health-label">Launch Readiness</span>
                <span class="health-value" id="overallPercent">0%</span>
            </div>
            <div class="health-bar"><div class="health-bar-fill" id="overallBar"></div></div>
            <div class="health-meta">
                <span><strong id="completedCount">0</strong> done</span>
                <span><strong id="runningCount">0</strong> active</span>
                <span><strong id="remainingCount">0</strong> left</span>
            </div>
        </div>
        <div class="health-divider"></div>
        <div class="health-item">
            <div class="health-top">
                <span class="health-label">Budget</span>
                <span class="health-value budget-remaining-val" id="budgetRemaining">$0</span>
            </div>
            <div class="health-bar"><div class="health-bar-fill budget-bar-fill" id="budgetBar"></div></div>
            <div class="health-meta">
                <span>Burn <strong id="budgetBurn">$552/mo</strong></span>
                <span>Runway <strong id="budgetRunway">33+ months</strong></span>
                <span>Break-even <strong>3 clients</strong></span>
            </div>
        </div>
        <div class="health-divider"></div>
        <div class="health-item">
            <div class="health-top">
                <span class="health-label">Agent Spend</span>
                <span class="health-value" id="agentSpendTonight">$0.00</span>
            </div>
            <div class="health-bar"><div class="health-bar-fill" id="agentSpendBar"></div></div>
            <div class="health-meta">
                <span>Tonight <strong id="agentSpendLimit">$0/$15</strong></span>
                <span>Month <strong id="agentSpendMonth">$0/$200</strong></span>
            </div>
        </div>
        <div class="health-divider"></div>
        <div class="health-item">
            <div class="health-top">
                <span class="health-label">Email Warmup</span>
                <span class="health-value" id="warmupProgress">Day 0</span>
            </div>
            <div class="health-bar"><div class="health-bar-fill" id="warmupBar"></div></div>
            <div class="health-meta">
                <span>Ready <strong id="warmupReadyDate">~April 21</strong></span>
                <span>GHL <strong id="ghlProgress">0/37</strong></span>
                <span>SOPs <strong id="sopCount">0</strong></span>
            </div>
        </div>
    </section>

    <!-- ===================== TAB NAVIGATION ===================== -->
    <nav class="tab-nav" id="tabNav">
        <button class="tab-btn active" data-tab="work" onclick="switchTab('work')">
            <span class="tab-icon">📋</span>
            <span class="tab-label">Work</span>
            <span class="tab-count" id="workTaskCount">0</span>
        </button>
        <button class="tab-btn" data-tab="activity" onclick="switchTab('activity')">
            <span class="tab-icon">📊</span>
            <span class="tab-label">Activity</span>
        </button>
        <button class="tab-btn" data-tab="launch" onclick="switchTab('launch')">
            <span class="tab-icon">🚀</span>
            <span class="tab-label">Launch Plan</span>
            <span class="tab-count" id="launchPlanPct">0%</span>
        </button>
        <button class="tab-btn" data-tab="reference" onclick="switchTab('reference')">
            <span class="tab-icon">📚</span>
            <span class="tab-label">Reference</span>
        </button>
    </nav>

    <!-- ===================== MAIN CONTENT ===================== -->
    <div class="main">
        <!-- TAB: Work (Two-Column) -->
        <section class="tab-content active" id="tab-work">
            <div class="work-grid">
                <!-- Left Column: Jasper's Tasks -->
                <div class="work-col">
                    <div class="section-header">
                        <h2>👤 Jasper's Tasks</h2>
                        <div class="priority-meta">
                            <span class="tab-count" id="jasperTaskCount">0</span>
                            <span class="meta-text">Only things YOU must do</span>
                        </div>
                    </div>
                    <div id="jasperTaskList"></div>
                </div>
                <!-- Right Column: AI Agent Tasks -->
                <div class="work-col">
                    <div class="section-header">
                        <h2>🤖 AI Agent Tasks</h2>
                        <div class="priority-meta">
                            <span class="tab-count" id="aiTaskCount">0</span>
                            <span class="meta-text">Overnight agents + Antigravity + MCP</span>
                        </div>
                    </div>
                    <div id="aiTaskList"></div>
                </div>
            </div>
        </section>

        <!-- TAB: Activity -->
        <section class="tab-content" id="tab-activity">
            <!-- Agent Status Board -->
            <div class="section-header">
                <h2>Agent Fleet</h2>
                <span class="section-badge">Status Board</span>
            </div>
            <div class="agent-status-board" id="agentStatusBoard"></div>

            <!-- Overnight Report Card -->
            <div id="overnightCard" style="margin-top: 24px;"></div>

            <!-- Burndown Chart (moved from above-tabs) -->
            <div class="burndown-card" id="burndownChart" style="padding: 0; margin-top: 24px;"></div>

            <!-- Agent Feed -->
            <div class="section-header" style="margin-top: 32px;">
                <h2>Agent Activity</h2>
                <span class="section-badge">Live Feed</span>
            </div>
            <div class="agent-feed" id="agentFeed"></div>

            <!-- Agent Cost Breakdown -->
            <div class="section-header" style="margin-top: 32px;">
                <h2>Agent Cost Breakdown</h2>
                <span class="section-badge">7-Day History</span>
            </div>
            <div id="agentCostBreakdown"></div>

            <!-- Decision Journal -->
            <div class="section-header" style="margin-top: 32px;">
                <h2>Decision Journal</h2>
                <span class="meta-text" id="decisionCount">0 decisions</span>
            </div>
            <div class="decision-filter" id="decisionFilter"></div>
            <div id="decisionLog"></div>

            <!-- Notes -->
            <div class="section-header" style="margin-top: 32px;">
                <h2>Notes</h2>
                <div style="display: flex; gap: 8px; align-items: center;">
                    <span class="meta-text" id="commentCount">0</span>
                    <button class="btn-sm" onclick="copyAllComments()">Copy All</button>
                </div>
            </div>
            <div class="comment-feed" id="commentFeed"></div>
        </section>

        <!-- TAB: Launch Plan -->
        <section class="tab-content" id="tab-launch">
            <div class="section-header">
                <h2>8-Week Launch Plan</h2>
                <span class="section-badge" id="launchPlanBadge">Week 1 of 8</span>
            </div>
            <div id="launchNextUp"></div>
            <div class="lp-pill-nav" id="lpPillNav"></div>
            <div id="launchPlanContent"></div>
        </section>

        <!-- TAB: Reference (Intel + Completed) -->
        <section class="tab-content" id="tab-reference">
            <div class="section-header">
                <h2>Intel & Documents</h2>
            </div>
            <div id="intelList"></div>

            <div class="section-header" style="margin-top: 32px;">
                <h2>Completed</h2>
                <span class="section-badge" id="completedBadge">0 tasks</span>
            </div>
            <div id="completedList"></div>
        </section>
    </div>

    <!-- Comment Modal -->
    <div class="comment-modal" id="commentModal">
        <div class="comment-modal-content">
            <div class="comment-modal-header">
                <h3>Leave a Note</h3>
                <button class="modal-close" onclick="closeComment()">✕</button>
            </div>
            <div class="comment-modal-target">Re: <span id="commentTarget"></span></div>
            <textarea id="commentInput" class="comment-textarea" placeholder="Type your note here..." rows="4"></textarea>
            <div class="comment-modal-actions">
                <button class="btn btn-primary" onclick="submitComment()">Save Note</button>
                <button class="btn btn-ghost" onclick="closeComment()">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Command Palette (Cmd+K) -->
    <div class="cmdk-overlay" id="cmdkOverlay" onclick="closeCommandPalette()">
        <div class="cmdk-modal" onclick="event.stopPropagation()">
            <div class="cmdk-search-row">
                <span class="cmdk-search-icon">🔍</span>
                <input type="text" class="cmdk-input" id="cmdkInput" placeholder="Type a command or search..." autocomplete="off" />
                <span class="cmdk-esc">ESC</span>
            </div>
            <div class="cmdk-results" id="cmdkResults"></div>
            <div class="cmdk-footer">
                <span>↑↓ navigate</span>
                <span>↵ select</span>
                <span>esc close</span>
            </div>
        </div>
    </div>

    <!-- Keyboard Shortcuts Help -->
    <div class="shortcuts-overlay" id="shortcutsOverlay" onclick="this.style.display='none'">
        <div class="shortcuts-modal" onclick="event.stopPropagation()">
            <h3>Keyboard Shortcuts</h3>
            <div class="shortcut-row"><kbd>⌘K</kbd><span>Command Palette</span></div>
            <div class="shortcut-row"><kbd>1</kbd><span>Work tab</span></div>
            <div class="shortcut-row"><kbd>2</kbd><span>Activity tab</span></div>
            <div class="shortcut-row"><kbd>3</kbd><span>Launch Plan tab</span></div>
            <div class="shortcut-row"><kbd>4</kbd><span>Reference tab</span></div>
            <div class="shortcut-row"><kbd>R</kbd><span>Refresh</span></div>
            <div class="shortcut-row"><kbd>?</kbd><span>This help</span></div>
            <button class="btn btn-ghost" onclick="document.getElementById('shortcutsOverlay').style.display='none'" style="margin-top:12px;">Close</button>
        </div>
    </div>

    <!-- Dock -->
    <nav class="dock">
        <button class="dock-btn" onclick="switchTab('work')" title="Work (1)">📋</button>
        <button class="dock-btn" onclick="switchTab('activity')" title="Activity (2)">📊</button>
        <button class="dock-btn" onclick="switchTab('launch')" title="Launch Plan (3)">🚀</button>
        <button class="dock-btn" onclick="switchTab('reference')" title="Reference (4)">📚</button>
        <button class="dock-btn" onclick="openCommandPalette()" title="Quick Actions (⌘K)">⚡</button>
        <button class="dock-btn" onclick="refreshDashboard()" title="Refresh (R)">↻</button>
    </nav>

    <div class="toast" id="toast"></div>

    <script src="data.js"></script>
    <script src="app.js"></script>
</body>
</html>
